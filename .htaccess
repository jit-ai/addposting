RewriteEngine On

# If your project is inside a folder like /add-posting/, keep this.
# Otherwise COMMENT it.
# RewriteBase /add-posting/

# -----------------------------
# SECURITY: Block sensitive files
# -----------------------------
RewriteRule ^(config|sql|includes/database\.php|debug) - [F,L]

# -----------------------------
# ALLOW assets directly
# -----------------------------
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteRule ^ - [L]

# -----------------------------
# SKIP existing files & folders
# -----------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# -----------------------------
# SEO ROUTES
# -----------------------------
RewriteRule ^category/([^/]+)/?$ category.php?category=$1 [L,QSA]
RewriteRule ^state/([^/]+)/?$ state.php?state=$1 [L,QSA]
RewriteRule ^city/([^/]+)/?$ city.php?city=$1 [L,QSA]
RewriteRule ^posting/([^/]+)/?$ posting.php?title=$1 [L,QSA]

RewriteRule ^search/([^/]+)/([^/]+)/?$ search.php?category=$1&location=$2 [L,QSA]
RewriteRule ^search/([^/]+)/?$ search.php?category=$1 [L,QSA]

# -----------------------------
# FALLBACK ROUTE (SAFE VERSION)
# -----------------------------
RewriteRule ^([^/]+)/([^/]+)/?$ search.php?category=$1&location=$2 [L,QSA]